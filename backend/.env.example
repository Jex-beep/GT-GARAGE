# Supabase — service-role key stays server-side only
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email — Resend (shop notification on new bookings)
RESEND_API_KEY=re_your_key_here
FROM_EMAIL=GT Garage <onboarding@resend.dev>
SHOP_EMAIL=youremail@gmail.com

# Security — FRONTEND_ORIGIN may be a comma-separated list (localhost + your live site)
FRONTEND_ORIGIN=http://localhost:4200
PORT=3000

# Public site address — used by the dynamic /sitemap.xml
SITE_URL=https://gtgarage.ph
